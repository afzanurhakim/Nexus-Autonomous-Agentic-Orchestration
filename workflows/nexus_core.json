  "connections": {
    "Webhook": {
      "main": [ [ { "node": "Cost Calculator", "type": "main", "index": 0 } ] ]
    },
    "Cost Calculator": {
      "main": [ [ { "node": "Monday.com", "type": "main", "index": 0 } ] ]
