      },
      "name": "Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [250, 300]
    },
    {
      "parameters": {
        "jsCode": "// Token Cost Calculation Logic\nconst input = $node[\"Webhook\"].json[\"body\"];\n// ... (The JS cost logic we wrote earlier)"
      },
      "name": "Cost Calculator",
      "type": "n8n-nodes-base.code",
      "typeVersion": 1,
      "position": [450, 300]
    },
    {
      "parameters": {
        "resource": "boardItem",
        "operation": "create",
        "boardId": "={{\".env.MONDAY_BOARD_ID\"}}",
        "name": "={{$json[\"title\"]}}"
      },
      "name": "Monday.com",
      "type": "n8n-nodes-base.mondayCom",
      "typeVersion": 1,
      "position": [650, 300]
    }
