# ==========================================
# ENVIRONMENT CONFIGURATION
# ==========================================

# --- AI REASONING CORE (SOUL) ---
# Your LLM Provider (OpenAI/Gemini/Anthropic)
OPENAI_API_KEY=your_openai_key_here
GEMINI_API_KEY=your_gemini_key_here
ANTHROPIC_API_KEY=your_anthropic_key_here
AGENT_MODE=production  # options: development, production, debug

# --- PROACTIVE ENGINE (HEARTBEAT) ---
# Frequency of the proactive scan (in minutes)
HEARTBEAT_INTERVAL=15

# --- N8N ORCHESTRATION (HANDSHAKE) ---
# The Webhook URL from your n8n workflow
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/nexus-task-sync
# Secure token for Header-based Authentication
N8N_AUTH_TOKEN=generate_a_secure_uuid_here

# --- MONDAY.COM INTEGRATION ---
MONDAY_API_KEY=your_monday_personal_token_here
MONDAY_BOARD_ID=1234567890

# --- NOTION ROI TELEMETRY ---
NOTION_API_KEY=your_notion_internal_integration_token_here
NOTION_DATABASE_ID=your_database_id_here

# --- INFRASTRUCTURE ---
# Local path for meeting transcript queue
TRANSCRIPT_PATH=./data/recordings/
# Log level (INFO, DEBUG, SUCCESS)
LOG_LEVEL=SUCCESS